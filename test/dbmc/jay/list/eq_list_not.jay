let is_nil l = 
  match l with
  | [] -> true
  | _ -> false
  end
in
let hd l = 
  match l with
  | x :: xs -> x
  | [] -> (0 0)
  end
in
let tl l = 
  match l with
  | x :: xs -> xs
  | [] -> (0 0)
  end
in
let rec eq_list l1 l2 = 
  if (is_nil l1) and (is_nil l2) then
    true
  else if (hd l1 == hd l2) then
    eq_list (tl l1) (tl l2)
  else
    false
  in
let s1 = [1] in
let x = input in
let s2 = [2,x] in
if eq_list s1 s2 then
  0
else
  let target = 1 in 1